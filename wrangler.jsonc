{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stock-alert",
  "main": "functions/worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "routing": {
      "has_user_worker": true
    }
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
